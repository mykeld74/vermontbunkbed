# Drizzle
# Replace with your DB credentials!
DATABASE_URL="postgres://user:password@host:port/db-name"

ORIGIN=""

# Better Auth
# For production use 32 characters and generated with high entropy
# https://www.better-auth.com/docs/installation
BETTER_AUTH_SECRET=""

# Comma-separated emails that get admin on signup and can create the first admin account
ADMIN_EMAILS=""

# Email (Resend) — required in production for password reset emails
RESEND_API_KEY=""
EMAIL_FROM="Vermont Bunk Beds <noreply@yourdomain.com>"

# Sanity CMS
PUBLIC_SANITY_PROJECT_ID=""
PUBLIC_SANITY_DATASET="production"

# Stripe
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
